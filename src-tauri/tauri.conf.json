{
  "$schema": "https://schema.tauri.app/json/tauri.conf.json",
  "productName": "AI Toolkit",
  "version": "1.0.0",
  "identifier": "com.ai-tool-manager.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI 工具箱",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxN0U1NEQ4NjQ0NDk2Q0MKUldUTWxrUmsyRlIra1MyQTVNbkpaSmpiOENvamVyT3p5TDg4YmJnMEIzL0JYOTdCUTZVUHNaaWoK",
      "endpoints": [
        "https://github.com/whyfail/ai-tool-manager/releases/latest/download/latest.json"
      ]
    }
  }
}
